# ═══════════════════════════════════════════════════════════════
# NacionalHidro Backend — Environment Variables
# ═══════════════════════════════════════════════════════════════

# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Pipefy
PIPEFY_CLIENT_ID=
PIPEFY_CLIENT_SECRET=
PIPEFY_API_URL=https://api.pipefy.com/graphql
PIPEFY_OAUTH_URL=https://app.pipefy.com/oauth/token

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contato@nacionalhidro.com.br
SMTP_PASS=

# FocusNFe — Emissão Fiscal
# Valores possíveis: PRODUCAO | HOMOLOGACAO
# ATENÇÃO: sem esta variável, emissões vão para HOMOLOGAÇÃO
FOCUS_NFE_AMBIENTE=PRODUCAO

# ═══════════════════════════════════════════════════════════════
# FocusNFe — Webhook URLs
# Configurar no painel da Focus para CADA empresa:
#   https://{DOMAIN}/webhooks/focus/nfse
#   https://{DOMAIN}/webhooks/focus/cte
#   https://{DOMAIN}/webhooks/focus/nfe
# As rotas estão em webhook.routes.ts sem autenticação JWT
# ═══════════════════════════════════════════════════════════════

# Puppeteer (Geração de PDFs)
# Descomente apenas se o servidor não tiver Chromium bundled
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Frontend URL (para links em emails, ex: reset de senha)
FRONTEND_URL=https://app.nacionalhidro.com.br

# JWT
JWT_SECRET=
