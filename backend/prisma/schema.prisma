  descricao     String
  statusTarefa  String      @default("PENDENTE")
  observacao    String?
  concluidaEm   DateTime?
  concluidaPor  String?
  createdAt     DateTime    @default(now())
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
}
