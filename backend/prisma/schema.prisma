generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_QzkomiupH0Z1@ep-calm-breeze-aciek47r.sa-east-1.aws.neon.tech/neondb?sslmode=require"
}

model User {
  id            String           @id @default(uuid())
  email         String           @unique
  name          String?
  password      String
  role          String           @default("user")
  roleId        String?
  departamento  String?
  isAtivo       Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  telefone      String?
  signatureUrl  String?
  pedidosCompra PedidoCompra[]   @relation("SolicitantePedidoCompra")
  categoria     CategoriaEquipe? @relation(fields: [roleId], references: [id])
}

model CategoriaEquipe {
  id                     String   @id @default(uuid())
  nome                   String   @unique
  canAccessFinanceiro    Boolean  @default(false)
  canAccessLogistica     Boolean  @default(false)
  canAccessFaturamento   Boolean  @default(false)
  canAccessComercial     Boolean  @default(true)
  canAccessOperacao      Boolean  @default(false)
  canAccessRH            Boolean  @default(false)
  canAccessEstoque       Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  canAccessCobranca      Boolean  @default(false)
  canAccessContasPagar   Boolean  @default(false)
  canAccessContasReceber Boolean  @default(false)
  canAccessDP            Boolean  @default(false)
  canAccessFrota         Boolean  @default(false)
  canAccessManutencao    Boolean  @default(false)
  canAccessMedicoes      Boolean  @default(false)
  users                  User[]
}

model Cliente {
  id                  String              @id @default(uuid())
  codigo              String?             @unique
  nome                String
  razaoSocial         String?
  nomeFantasia        String?
  documento           String              @unique
  inscricaoEstadual   String?
  inscricaoMunicipal  String?
  tipo                String              @default("PJ")
  segmento            String?
  endereco            String?
  numero              String?
  complemento         String?
  bairro              String?
  cidade              String?
  estado              String?
  cep                 String?
  uf                  String?
  pontoReferencia     String?
  email               String?
  telefone            String?
  celular             String?
  fax                 String?
  aniversarioReajuste DateTime?
  tipoFaturamento     String?
  vendedorResponsavel String?
  empresaFaturamento  String?
  aceitaCTe           Boolean             @default(false)
  porcentagemRL       Decimal?            @db.Decimal(5, 2)
  diasVencimentoRL    Int?
  bloquearCliente     Boolean             @default(false)
  orientacoesFatura   String?
  observacoesGerais   String?
  linkPortal          String?
  usuarioPortal       String?
  senhaPortal         String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  centrosCusto        Json?
  contatos            Json?
  matrizId            String?
  tipoCliente         String              @default("PADRAO")
  integracoesExigidas Json?
  agendamentos        Agendamento[]
  matriz              Cliente?            @relation("ClienteHierarquia", fields: [matrizId], references: [id])
  filiais             Cliente[]           @relation("ClienteHierarquia")
  contasPagar         ContaPagar[]        @relation("ClienteContasPagar")
  contasReceber       ContaReceber[]
  contratos           Contrato[]
  escalas             Escala[]
  faturamentos        Faturamento[]
  integracoes         IntegracaoCliente[]
  medicoes            Medicao[]
  ordensServico       OrdemServico[]
  propostas           Proposta[]
}

model Contrato {
  id                  String   @id @default(uuid())
  codigo              String   @unique
  clienteId           String
  status              String   @default("ATIVO")
  objeto              String
  valorMensal         Decimal  @db.Decimal(12, 2)
  valorTotal          Decimal? @db.Decimal(12, 2)
  dataInicio          DateTime
  dataVencimento      DateTime
  renovacaoAutomatica Boolean  @default(false)
  diaVencimentoFatura Int      @default(10)
  observacoes         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  cliente             Cliente  @relation(fields: [clienteId], references: [id])
}

model Proposta {
  id                    String                     @id @default(uuid())
  codigo                String                     @unique
  numero                Int                        @default(autoincrement())
  revisada              Boolean                    @default(false)
  clienteId             String
  vendedor              String?
  empresa               String?
  contato               String?
  cc                    String?
  naoEnviarAoCliente    Boolean                    @default(false)
  dataProposta          DateTime                   @default(now())
  dataValidade          DateTime
  validadeDias          Int                        @default(30)
  introducao            String?
  objetivo              String?
  descricaoValores      String?
  descricaoGarantia     String?
  condicoesPagamento    String?
  pRL                   Decimal?                   @db.Decimal(5, 2)
  cTe                   String?
  pagamentoAntecipado   String?
  valorTotal            Decimal                    @db.Decimal(10, 2)
  status                String                     @default("RASCUNHO")
  observacoes           String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  tipo                  String                     @default("INDIVIDUAL")
  propostaGlobalId      String?
  unidadeNome           String?
  unidadeCNPJ           String?
  unidadeEndereco       String?
  unidadeContato        String?
  vigente               Boolean                    @default(true)
  tipoProposta          String                     @default("COMERCIAL")
  escopoTecnico         String?
  dimensionamentoEquipe String?
  qtdEquipamentos       String?
  diasTrabalho          String?
  propostaComercialId   String?
  dataAprovacao         DateTime?
  percentualLocacao     Float?                     @default(90.0)
  percentualServico     Float?                     @default(10.0)
  adicionalFimSemana    Decimal?                   @default(50.0) @db.Decimal(10, 2)
  adicionalHoraExtra    Decimal?                   @default(35.0) @db.Decimal(10, 2)
  adicionalNoturno      Decimal?                   @default(35.0) @db.Decimal(10, 2)
  dataCancelamento      DateTime?
  franquiaHoras         Decimal?                   @default(8.0) @db.Decimal(10, 2)
  minimoHorasChamado    Decimal?                   @default(0) @db.Decimal(10, 2)
  motivoCancelamento    String?
  motivoReprovacao      String?
  agendamentos          Agendamento[]
  ordensServico         OrdemServico[]
  cliente               Cliente                    @relation(fields: [clienteId], references: [id])
  propostaGlobal        Proposta?                  @relation("PropostaUnidades", fields: [propostaGlobalId], references: [id])
  unidades              Proposta[]                 @relation("PropostaUnidades")
  acessorios            PropostaAcessorio[]
  equipe                PropostaEquipe[]
  itens                 PropostaItem[]
  responsabilidades     PropostaResponsabilidade[]
}

model PropostaItem {
  id            String   @id @default(uuid())
  propostaId    String
  equipamento   String
  quantidade    Int      @default(1)
  area          String?
  tipoCobranca  String?
  valorAcobrar  Decimal  @db.Decimal(10, 2)
  horasPorDia   Int?
  usoPrevisto   String?
  mobilizacao   Decimal? @db.Decimal(10, 2)
  valorTotal    Decimal  @db.Decimal(10, 2)
  horaAdicional Decimal? @db.Decimal(10, 2)
  proposta      Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)
}

model PropostaAcessorio {
  id         String   @id @default(uuid())
  propostaId String
  acessorio  String
  quantidade Int      @default(1)
  valor      Decimal? @db.Decimal(10, 2)
  proposta   Proposta @relation(fields: [propostaId], references: [id])
}

model PropostaResponsabilidade {
  id         String   @id @default(uuid())
  propostaId String
  tipo       String
  descricao  String
  proposta   Proposta @relation(fields: [propostaId], references: [id])
}

model PropostaEquipe {
  id          String   @id @default(uuid())
  propostaId  String
  nome        String?
  cargo       String?
  equipamento String?
  funcao      String?
  quantidade  Int      @default(1)
  proposta    Proposta @relation(fields: [propostaId], references: [id])
}

model OrdemServico {
  id                        String         @id @default(uuid())
  codigo                    String         @unique
  clienteId                 String
  propostaId                String?
  prioridade                String         @default("MEDIA")
  status                    String         @default("ABERTA")
  tecnicos                  String?
  materiais                 Json?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  acompanhante              String?
  almoco                    DateTime?
  contato                   String?
  dataInicial               DateTime       @default(now())
  diasSemana                String?
  empresa                   String         @default("NACIONAL HIDROSANEAMENTO EIRELI EPP")
  entrada                   DateTime?
  horaInicial               String?
  horasAdicionais           Decimal?       @db.Decimal(10, 2)
  horasTotais               Decimal?       @db.Decimal(10, 2)
  minimoHoras               Int?
  observacoes               String?
  quantidadeDia             String?
  saida                     DateTime?
  tipoCobranca              String?
  medicaoId                 String?
  dataBaixa                 DateTime?
  valorPrecificado          Decimal?       @db.Decimal(10, 2)
  statusPrecificacao        String?
  assinaturaCliente         String?
  justificativaFalha        String?
  qtdBicos                  Int?           @default(1)
  qtdPessoas                Int?
  turnos                    String?        @default("DIURNO")
  checkpoints               Json?
  justificativaCancelamento String?
  agendamentos              Agendamento[]
  itensCobranca             ItemCobranca[]
  logistica                 Logistica?
  manutencao                Manutencao?
  materiaisUtilizados       MaterialOS[]
  cliente                   Cliente        @relation(fields: [clienteId], references: [id])
  medicao                   Medicao?       @relation(fields: [medicaoId], references: [id])
  proposta                  Proposta?      @relation(fields: [propostaId], references: [id])
  rdos                      RDO[]
  servicos                  ServicoOS[]
}

model ItemCobranca {
  id                  String       @id @default(uuid())
  osId                String
  descricao           String
  quantidade          Decimal      @db.Decimal(10, 2)
  valorUnitario       Decimal      @db.Decimal(10, 2)
  percentualAdicional Decimal?     @db.Decimal(5, 2)
  valorTotal          Decimal      @db.Decimal(10, 2)
  createdAt           DateTime     @default(now())
