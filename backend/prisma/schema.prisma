generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String           @id @default(uuid())
  email         String           @unique
  name          String?
  password      String
  role          String           @default("user")
  roleId        String?
  departamento  String?
  isAtivo       Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  telefone              String?
  signatureUrl          String?
  resetPasswordToken    String?
  pedidosCompra PedidoCompra[]   @relation("SolicitantePedidoCompra")
  categoria     CategoriaEquipe? @relation(fields: [roleId], references: [id])
}

model CategoriaEquipe {
  id                     String   @id @default(uuid())
  nome                   String   @unique
  canAccessFinanceiro    Boolean  @default(false)
  canAccessLogistica     Boolean  @default(false)
  canAccessFaturamento   Boolean  @default(false)
  canAccessComercial     Boolean  @default(true)
  canAccessOperacao      Boolean  @default(false)
  canAccessRH            Boolean  @default(false)
  canAccessEstoque       Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  canAccessCobranca      Boolean  @default(false)
  canAccessContasPagar   Boolean  @default(false)
  canAccessContasReceber Boolean  @default(false)
  canAccessDP            Boolean  @default(false)
  canAccessFrota         Boolean  @default(false)
  canAccessManutencao    Boolean  @default(false)
  canAccessMedicoes      Boolean  @default(false)
  users                  User[]
}

model Cliente {
  id                  String              @id @default(uuid())
  codigo              String?             @unique
  clienteCodigo       String?
  nome                String              @unique
  razaoSocial         String?
  nomeFantasia        String?
  documento           String              @unique
  cnpj                String?
  cpf                 String?
  rg                  String?
  inscricaoEstadual   String?
  inscricaoMunicipal  String?
  tipo                String              @default("PJ")
  segmento            String?
  endereco            String?
  numero              String?
  complemento         String?
  bairro              String?
  cidade              String?
  estado              String?
  cep                 String?
  uf                  String?
  pontoReferencia     String?
  email               String?
  telefone            String?
  celular             String?
  fax                 String?
  aniversarioReajuste DateTime?
  tipoFaturamento     String?             // "Mensal"|"Quinzenal"|"Semanal"|"PorOS"
  diaBaseMensal       Int?
  diaBaseQuinzenalInicio Int?
  diaBaseQuinzenalFinal  Int?
  diaBaseSemanal      Int?
  vendedorResponsavel String?
  vendedorId          String?
  empresaFaturamento  String?
  empresaId           String?
  aceitaCTe           Boolean             @default(false)
  porcentagemRL       Decimal?            @db.Decimal(5, 2)
  diasVencimentoRL    Int?
  bloquearCliente     Boolean             @default(false)
  dataDesbloqueio     DateTime?
  codigoMunicipio     String?
  estadoSigla         String?
  observacaoCobranca  String?
  observacaoGeral     String?
  orientacoesFatura   String?
  observacoesGerais   String?
  linkPortal          String?
  usuarioPortal       String?
  senhaPortal         String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  centrosCusto        Json?
  matrizId            String?
  tipoCliente         String              @default("PADRAO")
  integracoesExigidas Json?
  categoriasExigidas  Json?
  prazoIntegracao     Int?                @default(365)
  contatos            Json?
  // ── Gap Analysis: 4.4 — Desconto de almoço variável por cliente ──
  descontaAlmoco      Boolean             @default(false)
  tempoAlmocoMin      Int?                @default(60)
  agendamentos        Agendamento[]
  matriz              Cliente?            @relation("ClienteHierarquia", fields: [matrizId], references: [id])
  filiais             Cliente[]           @relation("ClienteHierarquia")
  contasPagar         ContaPagar[]        @relation("ClienteContasPagar")
  contasReceber       ContaReceber[]
  contratos           Contrato[]
  escalas             Escala[]
  faturamentos        Faturamento[]
  integracoes         IntegracaoCliente[]
  medicoes            Medicao[]
  ordensServico       OrdemServico[]
  propostas           Proposta[]
  documentosAnexos    Documento[]
  contatosList        ClienteContato[]
  documentosList      ClienteDocumento[]
  historicos          HistoricoContato[]
}

model Contrato {
  id                  String   @id @default(uuid())
  codigo              String   @unique
  clienteId           String
  status              String   @default("ATIVO")
  objeto              String
  valorMensal         Decimal  @db.Decimal(12, 2)
  valorTotal          Decimal? @db.Decimal(12, 2)
  dataInicio          DateTime
  dataVencimento      DateTime
  renovacaoAutomatica Boolean  @default(false)
  diaVencimentoFatura Int      @default(10)
  observacoes         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  cliente             Cliente  @relation(fields: [clienteId], references: [id])
}

model Proposta {
  id                    String                     @id @default(uuid())
  codigo                String                     @unique
  numero                Int                        @default(autoincrement())
  revisada              Boolean                    @default(false)
  clienteId             String
  vendedor              String?
  empresa               String?
  contato               String?
  cc                    String?
  naoEnviarAoCliente    Boolean                    @default(false)
  dataProposta          DateTime                   @default(now())
  dataValidade          DateTime
  validadeDias          Int                        @default(30)
  introducao            String?
  objetivo              String?
  descricaoValores      String?
  descricaoGarantia     String?
  condicoesPagamento    String?
  pRL                   Decimal?                   @db.Decimal(5, 2)
  cTe                   String?
  pagamentoAntecipado   String?
  valorTotal            Decimal                    @db.Decimal(10, 2)
  status                String                     @default("RASCUNHO")
  observacoes           String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  tipo                  String                     @default("INDIVIDUAL")
  propostaGlobalId      String?
  unidadeNome           String?
  unidadeCNPJ           String?
  unidadeEndereco       String?
  unidadeContato        String?
  vigente               Boolean                    @default(true)
  tipoProposta          String                     @default("COMERCIAL")
  // Módulo 4: tipo Individual vs Contrato
  tipoContrato          String?                    // 'Individual' | 'Contrato'
  vigenciaMeses         Int?                       // used when tipoContrato='Contrato'
  escopoTecnico         String?
  dimensionamentoEquipe String?
  qtdEquipamentos       String?
  diasTrabalho          String?
  propostaComercialId   String?
  dataAprovacao         DateTime?
  percentualLocacao     Float?                     @default(90.0)
  percentualServico     Float?                     @default(10.0)
  adicionalFimSemana    Decimal?                   @default(50.0) @db.Decimal(10, 2)
  adicionalHoraExtra    Decimal?                   @default(35.0) @db.Decimal(10, 2)
  adicionalNoturno      Decimal?                   @default(35.0) @db.Decimal(10, 2)
  dataCancelamento      DateTime?
  franquiaHoras         Decimal?                   @default(8.0) @db.Decimal(10, 2)
  minimoHorasChamado    Decimal?                   @default(0) @db.Decimal(10, 2)
  motivoCancelamento    String?
  motivoReprovacao      String?
  agendamentos          Agendamento[]
  ordensServico         OrdemServico[]
  cliente               Cliente                    @relation(fields: [clienteId], references: [id])
  propostaGlobal        Proposta?                  @relation("PropostaUnidades", fields: [propostaGlobalId], references: [id])
  unidades              Proposta[]                 @relation("PropostaUnidades")
  acessorios            PropostaAcessorio[]
  equipe                PropostaEquipe[]
  itens                 PropostaItem[]
  responsabilidades     PropostaResponsabilidade[]
}

model PropostaItem {
  id               String   @id @default(uuid())
  propostaId       String
  equipamento      String
  quantidade       Int      @default(1)
  area             String?
  tipoCobranca     String?  // legacy string — being migrated to tipoCobrancaInt
  tipoCobrancaInt  Int?     // 1=Hora 2=Diaria 3=Frete 4=Fechada (new canonical field)
  valorAcobrar     Decimal  @db.Decimal(10, 2)
  horasPorDia      Int?
  usoPrevisto      String?
  mobilizacao      Decimal? @db.Decimal(10, 2)
  valorTotal       Decimal  @db.Decimal(10, 2)
  horaAdicional    Decimal? @db.Decimal(10, 2)
  proposta         Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)
}

model PropostaAcessorio {
  id         String   @id @default(uuid())
  propostaId String
  acessorio  String
  quantidade Int      @default(1)
  valor      Decimal? @db.Decimal(10, 2)
  proposta   Proposta @relation(fields: [propostaId], references: [id])
}

model PropostaResponsabilidade {
  id         String   @id @default(uuid())
  propostaId String
  tipo       String
  descricao  String
  proposta   Proposta @relation(fields: [propostaId], references: [id])
}

model PropostaEquipe {
  id          String   @id @default(uuid())
  propostaId  String
  nome        String?
  cargo       String?
  equipamento String?
  funcao      String?
  quantidade  Int      @default(1)
  proposta    Proposta @relation(fields: [propostaId], references: [id])
}

model OrdemServico {
  id                        String         @id @default(uuid())
  codigo                    String         @unique
  clienteId                 String
  propostaId                String?
  prioridade                String         @default("MEDIA")
  status                    String         @default("ABERTA")
  tecnicos                  String?
  materiais                 Json?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  acompanhante              String?
  almoco                    DateTime?
  contato                   String?
  dataInicial               DateTime       @default(now())
  diasSemana                String?
  empresa                   String         @default("NACIONAL HIDROSANEAMENTO EIRELI EPP")
  entrada                   DateTime?
  horaInicial               String?
  horasAdicionais           Decimal?       @db.Decimal(10, 2)
  horasTotais               Decimal?       @db.Decimal(10, 2)
  minimoHoras               Int?
  observacoes               String?
  quantidadeDia             String?
  saida                     DateTime?
  tipoCobranca              String?
  medicaoId                 String?
  dataBaixa                 DateTime?
  valorPrecificado          Decimal?       @db.Decimal(10, 2)
  statusPrecificacao        String?
  assinaturaCliente         String?
  justificativaFalha        String?
  qtdBicos                  Int?           @default(1)
  qtdPessoas                Int?
  turnos                    String?        @default("DIURNO")
  checkpoints               Json?
  justificativaCancelamento String?
  agendamentos              Agendamento[]
  itensCobranca             ItemCobranca[]
  logistica                 Logistica?
  manutencao                Manutencao?
  materiaisUtilizados       MaterialOS[]
  cliente                   Cliente        @relation(fields: [clienteId], references: [id])
  medicao                   Medicao?       @relation(fields: [medicaoId], references: [id])
  proposta                  Proposta?      @relation(fields: [propostaId], references: [id])
  rdos                      RDO[]
  servicos                  ServicoOS[]
  hospedagens               Hospedagem[]
  passagens                 Passagem[]
}

model ItemCobranca {
  id                  String       @id @default(uuid())
  osId                String
  descricao           String
  quantidade          Decimal      @db.Decimal(10, 2)
  valorUnitario       Decimal      @db.Decimal(10, 2)
  percentualAdicional Decimal?     @db.Decimal(5, 2)
  valorTotal          Decimal      @db.Decimal(10, 2)
  centroCustoId       String?
  // ── Gap Analysis 4.1/4.2: Tipo de cobrança por linha ──
  tipoCobranca        String?      // HORA, DIARIA, FRETE, EXECUCAO, HORA_ADICIONAL
  areaServico         String?      // Área/setor dentro do cliente
  horaInicio          String?
  horaFim             String?
  createdAt           DateTime     @default(now())
  os                  OrdemServico @relation(fields: [osId], references: [id])
  centroCusto         CentroCusto? @relation(fields: [centroCustoId], references: [id])
}

model Medicao {
  id                        String          @id @default(uuid())
  codigo                    String          @unique
  clienteId                 String
  periodo                   String?
  valorTotal                Decimal         @db.Decimal(10, 2)
  valorRL                   Decimal?        @db.Decimal(10, 2)
  valorNFSe                 Decimal?        @db.Decimal(10, 2)
  status                    String          @default("EM_ABERTO")
  observacoes               String?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  valorAprovado             Decimal?        @db.Decimal(10, 2)
  percentualAprovado        Decimal?        @db.Decimal(5, 2)
  motivoContestacao         String?
  contestadaEm              DateTime?
  aprovadaEm                DateTime?
  aprovadaPor               String?
  medicaoContestadaId       String?
  justificativaCancelamento String?
  cnpjFaturamento           String?
  emailDestinatario         String?
  subitens                  Json?
  adicional                 Decimal?        @db.Decimal(10, 2)
  cte                       Boolean         @default(false)
  desconto                  Decimal?        @db.Decimal(10, 2)
  porcentagemRL             Decimal?        @db.Decimal(5, 2)
  revisao                   Int             @default(0)
  solicitante               String?
  totalHora                 Decimal?        @db.Decimal(10, 2)
  totalServico              Decimal?        @db.Decimal(10, 2)
  vendedorId                String?
  tipoDocumento             String?         @default("RL")
  empresa                   String?
  emailCobrancaCC           String?
  dataCobranca              DateTime?
  dataAprovacaoInterna      DateTime?
  dataCancelamento          DateTime?
  motivoReprovacao          String?
  reprovadaEm               DateTime?
  cobrancasEmail            CobrancaEmail[]
  cliente                   Cliente         @relation(fields: [clienteId], references: [id])
  faturamentos              Faturamento[]
  ordensServico             OrdemServico[]
}

model ServicoOS {
  id          String       @id @default(uuid())
  osId        String
  equipamento String
  descricao   String?
  os          OrdemServico @relation(fields: [osId], references: [id])
}

model CobrancaEmail {
  id           String   @id @default(uuid())
  medicaoId    String
  destinatario String
  assunto      String
  corpo        String
  statusEnvio  String   @default("ENVIADO")
  dataEnvio    DateTime @default(now())
  erro         String?
  medicao      Medicao  @relation(fields: [medicaoId], references: [id])
}

model Produto {
  id            String                @id @default(uuid())
  nome          String
  descricao     String?
  sku           String?               @unique
  categoria     String?               // ELETRICO, MECANICO, HIDRAULICO, CONSUMIVEL, OUTROS
  fabricante    String?
  medida        String?               // dimensão/tamanho (ex: bico 3mm, mangueira 1/2")
  localizacao   String?               // endereçamento: C2-P10 (Corredor 2, Prateleira 10)
  precoCusto    Decimal               @db.Decimal(10, 2)
  precoVenda    Decimal               @db.Decimal(10, 2)
  estoqueAtual  Decimal               @default(0) @db.Decimal(10, 3)
  estoqueMinimo Decimal               @default(0) @db.Decimal(10, 3)
  unidadeMedida      String                 @default("UN")
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  movimentacoes      MovimentacaoEstoque[]
  itensPedidoCompra  ItemPedidoCompra[]
}

model MovimentacaoEstoque {
  id         String   @id @default(uuid())
  produtoId  String
  quantidade Decimal  @db.Decimal(10, 3)
  tipo       String
  motivo     String?
  usuarioId  String?
  createdAt  DateTime @default(now())
  produto    Produto  @relation(fields: [produtoId], references: [id])
}

model TransacaoFinanceira {
  id        String   @id @default(uuid())
  descricao String
  valor     Decimal  @db.Decimal(10, 2)
  data      DateTime @default(now())
  tipo      String
  categoria String?
  status    String   @default("PENDENTE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Funcionario {
  id                             String                 @id @default(uuid())
  nome                           String
  cargo                          String
  departamento                   String
  salario                        Decimal                @db.Decimal(10, 2)
  dataAdmissao                   DateTime
  cpf                            String                 @unique
  email                          String?
  ativo                          Boolean                @default(true)
  createdAt                      DateTime               @default(now())
  updatedAt                      DateTime               @updatedAt
  agencia                        String?
  bairro                         String?
  banco                          String?
  cep                            String?
  chavePix                       String?
  cidade                         String?
  complemento                    String?
  conta                          String?
  ctps                           String?
  dataNascimento                 DateTime?
  dependentes                    Json?
  documentos                     Json?
  endereco                       String?
  estado                         String?
  estadoCivil                    String?
  matricula                      String?                @unique
  nacionalidade                  String?                @default("Brasileira")
  nomeMae                        String?
  nomePai                        String?
  numero                         String?
  observacoes                    String?
  pis                            String?
  rg                             String?
  serieCtps                      String?
  tipoConta                      String?
  tipoContrato                   String                 @default("CLT")
  status                         String                 @default("ATIVO")
  feriasInicio                   DateTime?
  feriasFim                      DateTime?
  motivoAfastamento              Int?                   @default(0)
  inicioAfastamento              DateTime?
  fimAfastamento                 DateTime?
  empresa                        String?                // "hidro" | "locacao"
  funcao                         String?                // "jatista_junior" | "motorista_operador" | etc
  bloqueado                      Boolean                @default(false)
  dataDesligamento               DateTime?
  categoria                      String?
  categoriaCNH                   String?
  cnh                            String?
  dataVencimentoCNH              DateTime?
  dataVencimentoMOPP             DateTime?
  mopp                           Boolean                @default(false)
  telefone                       String?
  temRefeicao                    Boolean                @default(false)
  temValeTransporte              Boolean                @default(false)
  tipoRefeicao                   String?
  valorValeTransporte            Decimal?               @db.Decimal(10, 2)
  alocacaoAtividade              String?
  convenioMedico                 String?
  dataFeedback45                 DateTime?
  dataFeedback90                 DateTime?
  premioAssiduidade              String?
  regimeRefeicao                 String?
  seguroVidaAtivo                Boolean                @default(false)
  statusExperiencia45            String?
  statusExperiencia90            String?
  valeAlimentacao                String?
  valorJantar                    Decimal?               @db.Decimal(10, 2)
  valorRefeicao                  Decimal?               @db.Decimal(10, 2)
  /// { "emailCriado": true, "emailAcesso": "...", "acessosSistemas": true, "celularCorporativo": false, "beneficiosSolicitados": true }
  dadosOnboarding                Json?
  onboardingConcluido            Boolean                @default(false)
  anotacoesReferentesExperiencia Json?
  /// { "contratoEntregue": true, "sindicatoMapeado": true, "observacoes": "" }
  dadosEfetivacao                Json?
  efetivacaoConcluida            Boolean                @default(false)
  armarioVestiario               String?
  codESocial                     String?
  equipamentosAdministrativos    String?
  linkPastaDocumentos            String?
  previsaoRetornoINSS            DateTime?
  statusAsoDemissional           String?
  asosControle                   ASOControle[]
  admissoes                      Admissao[]
  afastamentos                   Afastamento[]
  controlesFerias                ControleFerias[]
  desligamentos                  Desligamento[]
  episEntregues                  EPIEntregue[]
  integracoes                    IntegracaoCliente[]
  treinamentos                   TreinamentoRealizado[]
  documentosAnexos               Documento[]
  ocorrencias                    OcorrenciaDisciplinar[]
  processos                      ProcessoTrabalhista[]
  hospedagens                    Hospedagem[]
  passagens                      Passagem[]
}

model EPI {
  id           String        @id @default(uuid())
  nome         String
  descricao    String?
  ca           String?
  validadeDias Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  entregas     EPIEntregue[]
}

model EPIEntregue {
  id            String      @id @default(uuid())
  funcionarioId String
  epiId         String
  dataEntrega   DateTime
  quantidade    Int         @default(1)
  tamanho       String?
  devolvido     Boolean     @default(false)
  dataDevolucao DateTime?
  observacoes   String?
  createdAt     DateTime    @default(now())
  epi           EPI         @relation(fields: [epiId], references: [id])
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id])
}

model Treinamento {
  id            String                 @id @default(uuid())
  nome          String
  descricao     String?
  validadeMeses Int?
  obrigatorio   Boolean                @default(true)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  realizacoes   TreinamentoRealizado[]
}

model TreinamentoRealizado {
  id             String      @id @default(uuid())
  funcionarioId  String
  treinamentoId  String
  dataRealizacao DateTime
  dataVencimento DateTime?
  certificadoUrl String?
  observacoes    String?
  createdAt      DateTime    @default(now())
  funcionario    Funcionario @relation(fields: [funcionarioId], references: [id])
  treinamento    Treinamento @relation(fields: [treinamentoId], references: [id])
}

model Afastamento {
  id            String      @id @default(uuid())
  funcionarioId String
  tipo          String
  dataInicio    DateTime
  dataFim       DateTime
  motivo        String?
  createdAt     DateTime    @default(now())
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id])
}

model IntegracaoCliente {
  id             String      @id @default(uuid())
  funcionarioId  String
  clienteId      String
  nome           String
  dataEmissao    DateTime
  dataVencimento DateTime
  status         String      @default("PENDENTE")
  observacoes    String?
  createdAt      DateTime    @default(now())
  arquivoUrl     String?
  cliente        Cliente     @relation(fields: [clienteId], references: [id])
  funcionario    Funcionario @relation(fields: [funcionarioId], references: [id])
}

model OcorrenciaDisciplinar {
  id            String      @id @default(uuid())
  funcionarioId String
  tipo          String      // ADVERTENCIA, SUSPENSAO, FEEDBACK, FALTA, MULTA
  data          DateTime
  descricao     String
  observacoes   String?
  valorDesconto Decimal?    @db.Decimal(10, 2)
  status        String      @default("PENDENTE") // PENDENTE, ASSINADO, LANCADO, CANCELADO
  testemunhas   String?
  arquivoUrl    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id])
}


model ProcessoTrabalhista {
  id              String      @id @default(uuid())
  funcionarioId   String
  numeroProcesso  String
  status          String      @default("ATIVO") // ATIVO, ENCERRADO, ACORDO
  valorEnvolvido  Decimal?    @db.Decimal(12, 2)
  advogado        String?
  descricao       String?
  dataAbertura    DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  funcionario     Funcionario @relation(fields: [funcionarioId], references: [id])
}

model Manutencao {
  id               String           @id @default(uuid())
  osId             String?          @unique
  equipamento      String?
  ultimaRevisao    DateTime?
  proximaRevisao   DateTime?
  historico        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  descricao        String?
  prioridade       String           @default("MEDIA")
  status           String           @default("PENDENTE")
  veiculoId        String?
  custoMaoObra     Decimal?         @db.Decimal(10, 2)
  custoPecas       Decimal?         @db.Decimal(10, 2)
  dataPagamento    DateTime?
  statusFinanceiro String           @default("PENDENTE")
  valorTotal       Decimal?         @db.Decimal(10, 2)
  os               OrdemServico?    @relation(fields: [osId], references: [id])
  veiculo          Veiculo?         @relation(fields: [veiculoId], references: [id])
  pecasUtilizadas  PecaManutencao[]
}

model MaterialOS {
  id              String       @id @default(uuid())
  osId            String
  produtoId       String
  descricao       String
