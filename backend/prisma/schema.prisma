  descricao   String?
  ativo       Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  stages      WorkflowStage[]
  fields      WorkflowField[]
  cards          WorkflowCard[]
  automations    WorkflowAutomation[]
  emailTemplates WorkflowEmailTemplate[]
}

model WorkflowStage {
  id          String               @id @default(uuid())
  workflowId  String
  nome        String
  ordem       Int                  @default(0)
  workflow    Workflow             @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  cards       WorkflowCard[]
  automations WorkflowAutomation[]
  fields      WorkflowField[]
}

model WorkflowField {
  id           String         @id @default(uuid())
  workflowId   String
  stageId      String?
  nome         String
  label        String
  descricao    String?
  tipo         String         @default("TEXT")
  obrigatorio  Boolean        @default(false)
  isStartField Boolean        @default(false)
  opcoes       Json?
  ordem        Int            @default(0)
  workflow     Workflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stage        WorkflowStage? @relation(fields: [stageId], references: [id])
}

model WorkflowCard {
  id         String        @id @default(uuid())
  workflowId String
  stageId    String
  titulo     String
  dados      Json          @default("{}")
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  workflow   Workflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stage      WorkflowStage @relation(fields: [stageId], references: [id])
}

model WorkflowAutomation {
  id              String                 @id @default(uuid())
  workflowId      String
  stageId         String?
  emailTemplateId String?
  tipo            String                 @default("WHATSAPP")
  evento          String                 @default("ENTRADA_FASE")
  config          Json                   @default("{}")
  ativo           Boolean                @default(true)
  workflow        Workflow               @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stage           WorkflowStage?         @relation(fields: [stageId], references: [id])
  emailTemplate   WorkflowEmailTemplate? @relation(fields: [emailTemplateId], references: [id])
}

model WorkflowEmailTemplate {
  id          String               @id @default(uuid())
  workflowId  String
  nome        String
  assunto     String
  corpo       String               @db.Text
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  workflow    Workflow             @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  automations WorkflowAutomation[]
}

model Documento {
  id             String       @id @default(uuid())
  nome           String
  tipo           String       // ASO, PGR, PCMSO, NR10, etc
  dataEmissao    DateTime?
  dataVencimento DateTime?
  status         String       @default("VALIDO")
  arquivoUrl     String?
  funcionarioId  String?
  clienteId      String?
  observacoes    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  cliente        Cliente?     @relation(fields: [clienteId], references: [id])
  funcionario    Funcionario? @relation(fields: [funcionarioId], references: [id])
}

model NaturezaContabil {
  id        String   @id @default(uuid())
  descricao String
  inativo   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmpresaBanco {
  id        String    @id @default(uuid())
  banco     String
  agencia   String
  conta     String
  empresaId String
  empresa   EmpresaCNPJ @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model ClienteContato {
  id                 String   @id @default(uuid())
  clienteId          String
  nome               String
  setor              String?
  email              String?
  telefone           String?
  celular            String?
  ramal              String?
  tipo               String?  // "Comercial"|"Técnico"|"Comprador"|"Financeiro"|"Operacional"
  emailMedicao       Boolean  @default(false)
  emailProposta      Boolean  @default(false)
  cliente            Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
}

model ClienteDocumento {
  id             String    @id @default(uuid())
  clienteId      String
  descricao      String
  urlArquivo     String?
  motivoExclusao String?
  deletedAt      DateTime?
  criadoPorId    String?
  cliente        Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
}

model HistoricoContato {
  id           String    @id @default(uuid())
  clienteId    String
  vendedorId   String?
  contatoId    String?
  status       String    @default("NOVO") // "NOVO"|"RETORNAR LIGAÇÃO"|"FINALIZADO"
  dataContato  DateTime?
  dataAgendado DateTime?
  observacoes  String?
  cliente      Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ══════════════════════════════════════════════════════════════════════════════
// MÓDULO 5 — LOGÍSTICA (OS + Escala)
// StatusOS/Escala: 0=Cancelada | 1=Aberta | 2=Executada
// TipoCobranca:   1=Hora | 2=Diaria | 3=Frete | 4=Fechada
// StatusOperacional: 0=Nenhum | 1=Férias | 2=Atestado | 3=Pátio | 4=BancoHoras
// ══════════════════════════════════════════════════════════════════════════════

model OSLogistica {
  id                 Int                    @id @default(autoincrement())
  codigo             String?
  numero             Int?
  status             Int                    @default(1)
  propostaId         String?
  clienteId          String?
  contatoId          String?
  equipamentoId      String?
  empresaId          String?
  tipoCobranca       Int?
  dataInicial        DateTime?
  horaInicial        String?
  diasSemana         Json?
  quantidadeDia      Int?
  acompanhante       String?
  horaPadrao         String?
  horaEntrada        String?
  horaSaida          String?
  horaAlmoco         String?
  horaTolerancia     String?
  horaTotal          String?
  horaAdicional      String?
  descontarAlmoco    Boolean                @default(false)
  observacoes        String?
  motivoCancelamento String?
  dataCancelamento   DateTime?
  urlArquivo         String?
  criadoPorId        String?
  dataCriacao        DateTime?
  servicos           OSLogisticaServico[]
  escala             EscalaLogistica?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
}

model OSLogisticaServico {
  id            Int         @id @default(autoincrement())
  ordemId       Int
  ordem         OSLogistica @relation(fields: [ordemId], references: [id], onDelete: Cascade)
  discriminacao String
}

model EscalaLogistica {
  id                        Int                          @id @default(autoincrement())
  status                    Int                          @default(1)
  ordemId                   Int?                         @unique
  ordem                     OSLogistica?                 @relation(fields: [ordemId], references: [id])
  clienteId                 String?
  equipamentoId             String?
  empresaId                 String?
  data                      DateTime?
  hora                      String?
  observacoes               String?
  funcionariosIndisponiveis String?
  funcionarios              EscalaLogisticaFuncionario[]
  veiculos                  EscalaLogisticaVeiculo[]
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt
}

model EscalaLogisticaFuncionario {
  id             Int             @id @default(autoincrement())
  escalaId       Int
  escala         EscalaLogistica @relation(fields: [escalaId], references: [id], onDelete: Cascade)
  funcionarioId  String
  statusOperacao Int?            @default(0)
  ausente        Boolean         @default(false)
}

model EscalaLogisticaVeiculo {
  id         Int             @id @default(autoincrement())
  escalaId   Int
  escala     EscalaLogistica @relation(fields: [escalaId], references: [id], onDelete: Cascade)
  veiculoId  String
  manutencao Boolean         @default(false)
}
